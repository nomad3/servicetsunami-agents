{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Luna",
  "version": "0.1.0",
  "identifier": "com.agentprovision.luna",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Luna",
        "label": "main",
        "width": 420,
        "height": 680,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true
      },
      {
        "title": "Luna Spatial HUD",
        "label": "spatial_hud",
        "fullscreen": false,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "maximized": true,
        "shadow": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Luna — AI Assistant"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* https://agentprovision.com https://*.agentprovision.com wss://agentprovision.com wss://*.agentprovision.com https://cdn.jsdelivr.net; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; worker-src blob:; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/AppIcon.appiconset/Contents.json"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "infoPlist": {
        "NSCameraUsageDescription": "Luna uses your camera to recognize hand gestures.",
        "NSAccessibilityUsageDescription": "Luna uses Accessibility access to move the cursor and click via hand gestures."
      }
    },
    "iOS": {
      "minimumSystemVersion": "16.0",
      "developmentTeam": ""
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nomad3/servicetsunami-agents/releases/latest/download/latest.json"
      ],
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
