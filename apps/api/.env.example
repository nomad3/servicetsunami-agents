# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/agentprovision

# Storage
DATA_STORAGE_PATH=/app/storage

# Temporal Workflow
# Use 'temporal:7233' when running in Docker, 'localhost:7233' when running locally
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
DEFAULT_WORKFLOW_TIMEOUT_SECONDS=600

# MCP Server
MCP_SERVER_URL=http://localhost:8085
MCP_API_KEY=dev_mcp_key
MCP_ENABLED=true

# LLM Configuration (Required for AI chat)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
PLATFORM_SHARED_CREDENTIALS_TENANT_ID=
PLATFORM_CODEX_AUTH_JSON=

# OAuth2 - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback

# OAuth2 - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/oauth/github/callback

# OAuth2 - LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/oauth/linkedin/callback

# OAuth2 - Microsoft (Outlook Mail)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/oauth/microsoft/callback

# OAuth2 - Higgsfield (CLI integration catalog Wave 1a, #270)
# BYO-account model: each tenant brings their own Higgsfield account and
# calls bill against their credits. The api-owned PKCE flow needs a
# registered OAuth client; create one in Higgsfield, register the
# redirect URI, and stamp client_id + secret + the EXACT redirect URI
# into these env vars on the api container. Without them /start
# returns 503.
HIGGSFIELD_OAUTH_CLIENT_ID=your-higgsfield-client-id
HIGGSFIELD_OAUTH_CLIENT_SECRET=your-higgsfield-client-secret
HIGGSFIELD_OAUTH_REDIRECT_URI=https://higgsfield.ai/cli/authcode
# Optional overrides — leave unset to use Wave 1a defaults.
# HIGGSFIELD_AUTH_URL=https://higgsfield.ai/oauth/authorize
# HIGGSFIELD_TOKEN_URL=https://higgsfield.ai/oauth/token
# HIGGSFIELD_OAUTH_SCOPE=mcp.read mcp.write generate
# HIGGSFIELD_MCP_URL=https://api.higgsfield.ai/mcp

# CLI Phase 1 ship (#177): when "true", `/api/v1/tasks-fanout/run`
# dispatches a real FanoutChatCliWorkflow to Temporal on the
# `agentprovision-code` queue instead of the in-memory stub. Default
# "false" keeps the prototype's demo-safe stub as the path. Rollback
# is a one-line flip back.
USE_REAL_FANOUT_WORKFLOW=false

# Deployment environment — gates dev-only side-effects like the
# demo-user seed in init_db.py. Settings.ENVIRONMENT defaults to
# "production" (fail-closed) so a forgotten env var never seeds the
# demo account in prod. Local devs MUST set this to "local" to get
# the `test@example.com / DemoPass123!` account auto-seeded on
# first startup.
ENVIRONMENT=local

# Transactional email (password recovery, invitations, system
# notifications). Leave EMAIL_SMTP_HOST unset in local dev — the
# sender falls back to log-only and prints the reset link at WARNING
# level. Set the full quintet on the deploy runner (and only there)
# to flip the API into real delivery:
#   EMAIL_SMTP_HOST=smtp.sendgrid.net          # or smtp.postmarkapp.com, AWS SES regional, ...
#   EMAIL_SMTP_PORT=587                        # 587 (STARTTLS) or 465 (implicit TLS)
#   EMAIL_SMTP_USERNAME=apikey                 # provider-specific
#   EMAIL_SMTP_PASSWORD=<api-key>              # provider-specific
#   EMAIL_FROM=noreply@agentprovision.com
#   EMAIL_FROM_NAME=AgentProvision
#   EMAIL_SMTP_USE_TLS=true                    # mandatory; false is refused at login()
# EMAIL_SMTP_HOST is allowlisted (SendGrid, Postmark, Mailgun, Gmail,
# Fastmail, AWS SES regional, localhost) — see app/services/email_sender.py.
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=noreply@agentprovision.com
EMAIL_FROM_NAME=AgentProvision
EMAIL_SMTP_USE_TLS=true
