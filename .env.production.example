# AgentProvision Production Environment Variables
# Copy this to apps/api/.env on your production server and update the values

# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PRODUCTION_DB_PASSWORD@db:5432/agentprovision

# ==========================================
# Security - CRITICAL: CHANGE THESE VALUES
# ==========================================
# Generate a strong secret key with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_KEY_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# Storage
# ==========================================
DATA_STORAGE_PATH=/app/storage

# ==========================================
# Temporal Configuration
# ==========================================
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
DEFAULT_WORKFLOW_TIMEOUT_SECONDS=600

# ==========================================
# MCP Server Configuration (Databricks)
# ==========================================
MCP_SERVER_URL=https://mcp.agentprovision.com
MCP_API_KEY=your_production_mcp_api_key_here
MCP_ENABLED=true

# ==========================================
# LLM Configuration - Claude AI
# ==========================================
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ACTUAL_KEY_HERE
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ==========================================
# OAuth2 - Higgsfield (CLI integration catalog Wave 1a, #270)
# ==========================================
# BYO-account model: each tenant brings their own Higgsfield account
# and calls bill against their credits. Register an OAuth client with
# Higgsfield, set the redirect URI there, and copy the EXACT same
# value into HIGGSFIELD_OAUTH_REDIRECT_URI here. Without these env
# vars /api/v1/higgsfield-auth/start returns 503.
HIGGSFIELD_OAUTH_CLIENT_ID=your-higgsfield-client-id
HIGGSFIELD_OAUTH_CLIENT_SECRET=your-higgsfield-client-secret
HIGGSFIELD_OAUTH_REDIRECT_URI=https://higgsfield.ai/cli/authcode
# Optional overrides — leave commented to use Wave 1a defaults.
# HIGGSFIELD_AUTH_URL=https://higgsfield.ai/oauth/authorize
# HIGGSFIELD_TOKEN_URL=https://higgsfield.ai/oauth/token
# HIGGSFIELD_OAUTH_SCOPE=mcp.read mcp.write generate
# HIGGSFIELD_MCP_URL=https://api.higgsfield.ai/mcp

# ==========================================
# Optional: Monitoring & Logging
# ==========================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# LOG_LEVEL=INFO
# ENVIRONMENT controls the demo-seed gate in init_db.py. Default is
# "production" (so a forgotten env var fails closed) — only set this
# to "local" or "dev" on developer machines where you want the
# test@example.com / DemoPass123! account seeded automatically.
ENVIRONMENT=production

# ==========================================
# Transactional Email (password recovery)
# ==========================================
# Required for password-reset email delivery. Without these the API
# falls back to log-only mode — users will never receive the email.
# EMAIL_SMTP_HOST is allowlisted in app/services/email_sender.py
# (SendGrid, Postmark, Mailgun, Gmail, Fastmail, AWS SES regional).
EMAIL_SMTP_HOST=smtp.sendgrid.net
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=apikey
EMAIL_SMTP_PASSWORD=YOUR_PROVIDER_API_KEY_HERE
EMAIL_FROM=noreply@agentprovision.com
EMAIL_FROM_NAME=AgentProvision
EMAIL_SMTP_USE_TLS=true
